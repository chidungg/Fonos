<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="18dp"
    tools:context=".AudioPlayer">

    <!-- top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_back_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="‹"
            android:textColor="#111827"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Audio Player"
            android:textColor="#2563EB"
            android:textSize="9sp" />

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="25dp" />

    <!-- book cover -->
    <TextView
        android:layout_width="186dp"
        android:layout_height="246dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_audio_book_cover" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="31dp" />

    <!-- book title -->
    <TextView
        android:id="@+id/txtBookTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Tên sách"
        android:textColor="#111827"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- chapter title -->
    <TextView
        android:id="@+id/txtChapterTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="5dp"
        android:text="Chương 1"
        android:textColor="#64748B"
        android:textSize="13sp"
        android:textStyle="bold" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="41dp" />

    <!-- seek bar -->
    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="1000"
        android:progress="0"
        android:progressTint="#2563EB"
        android:thumbTint="#2563EB" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="8dp" />

    <!-- time row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtElapsed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00"
            android:textColor="#64748B"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/txtDuration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="00:00"
            android:textColor="#64748B"
            android:textSize="11sp" />

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="14dp" />

    <!-- control buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- rewind -->
        <TextView
            android:id="@+id/btnRewind"
            android:layout_width="65dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="10s"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <Space
            android:layout_width="16dp"
            android:layout_height="match_parent" />

        <!-- pause button -->
        <TextView
            android:id="@+id/btnPause"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:background="@drawable/bg_audio_pause_button"
            android:gravity="center"
            android:text="Pause"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <Space
            android:layout_width="16dp"
            android:layout_height="match_parent" />

        <!-- forward -->
        <TextView
            android:id="@+id/btnForward"
            android:layout_width="65dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="10s"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- chapter and stop buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnPreviousChapter"
            android:layout_width="92dp"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Previous"
            android:textColor="#111827"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnStop"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Stop"
            android:textColor="#2563EB"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnNextChapter"
            android:layout_width="92dp"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Next"
            android:textColor="#111827"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
