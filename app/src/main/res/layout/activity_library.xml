<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1016"
    tools:context=".Library">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="17dp"
            android:paddingBottom="90dp">

            <!-- small label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Library"
                android:textColor="#6F7685"
                android:textSize="8sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <!-- title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thư viện của tôi"
                android:textColor="#FFFFFF"
                android:textSize="23sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="26dp" />

            <!-- filter buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="29dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/filterAll"
                    android:layout_width="48dp"
                    android:layout_height="29dp"
                    android:background="@drawable/bg_filter_active"
                    android:gravity="center"
                    android:text="Tất cả"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/filterDownloaded"
                    android:layout_width="72dp"
                    android:layout_height="29dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_filter_inactive"
                    android:gravity="center"
                    android:text="Đã tải"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/filterFavorite"
                    android:layout_width="72dp"
                    android:layout_height="29dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_filter_inactive"
                    android:gravity="center"
                    android:text="Yêu thích"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="27dp" />

            <!-- book grid row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="184dp"
                android:orientation="horizontal">

                <!-- book 1 -->
                <LinearLayout
                    android:id="@+id/bookItem1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="112dp"
                        android:layout_height="152dp"
                        android:background="@drawable/bg_library_cover_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tên sách"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="101dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/bg_library_progress_track"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="45dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_library_progress_active" />

                    </LinearLayout>

                </LinearLayout>

                <Space
                    android:layout_width="23dp"
                    android:layout_height="match_parent" />

                <!-- book 2 -->
                <LinearLayout
                    android:id="@+id/bookItem2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="112dp"
                        android:layout_height="152dp"
                        android:background="@drawable/bg_library_cover_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tên sách"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="101dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/bg_library_progress_track"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="80dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_library_progress_active" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="7dp" />

            <!-- book grid row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="184dp"
                android:orientation="horizontal">

                <!-- book 3 -->
                <LinearLayout
                    android:id="@+id/bookItem3"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="112dp"
                        android:layout_height="152dp"
                        android:background="@drawable/bg_library_cover_green" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tên sách"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="101dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/bg_library_progress_track"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="20dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_library_progress_active" />

                    </LinearLayout>

                </LinearLayout>

                <Space
                    android:layout_width="23dp"
                    android:layout_height="match_parent" />

                <!-- book 4 -->
                <LinearLayout
                    android:id="@+id/bookItem4"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="112dp"
                        android:layout_height="152dp"
                        android:background="@drawable/bg_library_cover_purple" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tên sách"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="101dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/bg_library_progress_track"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_library_progress_active" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- bottom navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="7dp"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌂"
                android:textColor="#8B93A3"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#8B93A3"
                android:textSize="7sp" />

        </LinearLayout>

        <!-- explore -->
        <LinearLayout
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌕"
                android:textColor="#8B93A3"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore"
                android:textColor="#8B93A3"
                android:textSize="7sp" />

        </LinearLayout>

        <!-- library active -->
        <LinearLayout
            android:id="@+id/navLibrary"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▤"
                android:textColor="#FF7A00"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Library"
                android:textColor="#FF7A00"
                android:textSize="7sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- category -->
        <LinearLayout
            android:id="@+id/navCategory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓"
                android:textColor="#8B93A3"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="#8B93A3"
                android:textSize="7sp" />

        </LinearLayout>

        <!-- profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/bg_circle_gray" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Profile"
                android:textColor="#8B93A3"
                android:textSize="7sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>