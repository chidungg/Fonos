<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".HomePage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:paddingTop="12dp"
            android:paddingBottom="92dp">

            <!-- Small label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#2563EB"
                android:textSize="8sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="9dp" />

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_circle_orange" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="My app"
                    android:textColor="#111827"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_circle_dark" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="21dp" />

            <!-- Search bar -->
            <EditText
                android:id="@+id/edtSearch"
                android:layout_width="match_parent"
                android:layout_height="29dp"
                android:background="@drawable/bg_home_search"
                android:hint="Tìm sách, tác giả, podcast..."
                android:inputType="text"
                android:paddingStart="15dp"
                android:paddingEnd="15dp"
                android:textColor="#111827"
                android:textColorHint="#64748B"
                android:textSize="9sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="15dp" />

            <!-- Featured book card -->
            <LinearLayout
                android:id="@+id/bookFeatured"
                android:layout_width="match_parent"
                android:layout_height="95dp"
                android:background="@drawable/bg_featured_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="15dp"
                android:paddingEnd="21dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sách nổi bật"
                        android:textColor="#DBEAFE"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Tên sách"
                        android:textColor="#FFFFFF"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="Short Detail"
                        android:textColor="#DBEAFE"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/btnListenTrial"
                        android:layout_width="58dp"
                        android:layout_height="22dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_white_button"
                        android:gravity="center"
                        android:text="Nghe thử"
                        android:textColor="#2563EB"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <TextView
                    android:layout_width="46dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_book_cover_dark" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="13dp" />

            <!-- Continue listening title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nghe tiếp"
                android:textColor="#111827"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <!-- Continue listening card -->
            <LinearLayout
                android:id="@+id/bookContinue"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="55dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bg_book_cover_brown" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên sách"
                        android:textColor="#111827"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Chương 4 • còn 21 phút"
                        android:textColor="#64748B"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="13dp"
                        android:background="@drawable/bg_progress_track"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="58dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_progress_orange" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="5dp" />

            <!-- Category title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Danh mục"
                android:textColor="#111827"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <!-- Categories -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center"
                        android:paddingStart="11dp"
                        android:paddingEnd="11dp"
                        android:text="Kinh doanh"
                        android:textColor="#111827"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:layout_marginStart="7dp"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center"
                        android:paddingStart="11dp"
                        android:paddingEnd="11dp"
                        android:text="Tâm lý"
                        android:textColor="#111827"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:layout_marginStart="7dp"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center"
                        android:paddingStart="11dp"
                        android:paddingEnd="11dp"
                        android:text="Lịch sử"
                        android:textColor="#111827"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:layout_marginStart="7dp"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center"
                        android:paddingStart="11dp"
                        android:paddingEnd="11dp"
                        android:text="Văn học"
                        android:textColor="#111827"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </HorizontalScrollView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="14dp" />

            <!-- Suggestion title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gợi ý cho bạn"
                android:textColor="#111827"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="11dp" />

            <!-- Suggestion books -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/bookSuggestion1"
                    android:layout_width="55dp"
                    android:layout_height="88dp"
                    android:background="@drawable/bg_book_cover_brown"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/bookSuggestion2"
                    android:layout_width="55dp"
                    android:layout_height="88dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_book_cover_dark"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/bookSuggestion3"
                    android:layout_width="55dp"
                    android:layout_height="88dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_book_cover_dark"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="7dp"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- Home active -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌂"
                android:textColor="#2563EB"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#2563EB"
                android:textSize="7sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Explore -->
        <LinearLayout
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌕"
                android:textColor="#64748B"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore"
                android:textColor="#64748B"
                android:textSize="7sp" />

        </LinearLayout>

        <!-- Library -->
        <LinearLayout
            android:id="@+id/navLibrary"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▤"
                android:textColor="#64748B"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Library"
                android:textColor="#64748B"
                android:textSize="7sp" />

        </LinearLayout>

        <!-- Category -->
        <LinearLayout
            android:id="@+id/navCategory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓"
                android:textColor="#64748B"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="#64748B"
                android:textSize="7sp" />

        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/bg_circle_gray" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Profile"
                android:textColor="#64748B"
                android:textSize="7sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
