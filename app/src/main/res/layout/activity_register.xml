<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1016"
    tools:context=".Register">

    <!-- Brown decoration circle -->
    <View
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="-42dp"
        android:background="@drawable/bg_brown_circle" />

    <!-- Blue decoration circle at bottom left -->
    <View
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-75dp"
        android:layout_marginBottom="-65dp"
        android:background="@drawable/bg_blue_circle" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="31dp"
            android:paddingEnd="31dp"
            android:paddingTop="22dp"
            android:paddingBottom="28dp">

            <!-- Top label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Register / Sign Up"
                android:textColor="#6F7685"
                android:textSize="9sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <!-- Back button -->
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_back_button"
                android:gravity="center"
                android:text="‹"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tạo tài khoản"
                android:textColor="#FFFFFF"
                android:textSize="25sp"
                android:textStyle="bold" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Đăng ký để lưu thư viện và tiến độ nghe"
                android:textColor="#9BA1AD"
                android:textSize="12sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="32dp" />

            <!-- Google Register -->
            <TextView
                android:id="@+id/btnGoogleRegister"
                android:layout_width="match_parent"
                android:layout_height="41dp"
                android:background="@drawable/bg_button_outline"
                android:gravity="center"
                android:text="G        Đăng ký với Google"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="11dp" />

            <!-- Apple Register -->
            <TextView
                android:id="@+id/btnAppleRegister"
                android:layout_width="match_parent"
                android:layout_height="41dp"
                android:background="@drawable/bg_button_outline"
                android:gravity="center"
                android:text="●        Đăng ký với Apple"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="28dp" />

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#252B38" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp"
                    android:text="hoặc"
                    android:textColor="#9BA1AD"
                    android:textSize="11sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#252B38" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- Name label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Họ và tên"
                android:textColor="#B5BBC8"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtFullName"
                android:layout_width="match_parent"
                android:layout_height="41dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_input"
                android:hint="Nguyễn Văn A"
                android:inputType="textPersonName"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#7E8492"
                android:textSize="12sp" />

            <!-- Email label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-2dp"
                android:text="Email"
                android:textColor="#B5BBC8"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtEmailRegister"
                android:layout_width="match_parent"
                android:layout_height="41dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_input"
                android:hint="example@email.com"
                android:inputType="textEmailAddress"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#7E8492"
                android:textSize="12sp" />

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-2dp"
                android:text="Mật khẩu"
                android:textColor="#B5BBC8"
                android:textSize="11sp"
                android:textStyle="bold" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="41dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_input"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <EditText
                    android:id="@+id/edtPasswordRegister"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@+id/txtHidePasswordRegister"
                    android:background="@android:color/transparent"
                    android:hint="Tối thiểu 8 ký tự"
                    android:inputType="textPassword"
                    android:padding="0dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#7E8492"
                    android:textSize="12sp" />

                <TextView
                    android:id="@id/txtHidePasswordRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:gravity="center"
                    android:text="Ẩn"
                    android:textColor="#FF7A00"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <!-- Confirm password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-2dp"
                android:text="Nhập lại mật khẩu"
                android:textColor="#B5BBC8"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="41dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_input"
                android:hint="Xác nhận mật khẩu"
                android:inputType="textPassword"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#7E8492"
                android:textSize="12sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- Terms checkbox -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/cbTerms"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:buttonTint="#6F7685" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Tôi đồng ý với Điều khoản &amp; Chính sách"
                    android:textColor="#9BA1AD"
                    android:textSize="10sp" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="14dp" />

            <!-- Create account button -->
            <TextView
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/bg_button_orange"
                android:gravity="center"
                android:text="Tạo tài khoản"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <!-- Login link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã có tài khoản? "
                    android:textColor="#9BA1AD"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/txtLoginNow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng nhập"
                    android:textColor="#FF7A00"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- AUDIO label -->
    <TextView
        android:layout_width="60dp"
        android:layout_height="33dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/bg_audio_label"
        android:gravity="center"
        android:text="AUDIO"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold" />

</FrameLayout>