        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:statusBarColor">@color/fonos_background</item>
        <item name="android:navigationBarColor">@color/fonos_surface</item>
        <item name="colorPrimary">@color/fonos_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/fonos_surface</item>
        <item name="colorOnSurface">@color/fonos_text</item>
    </style>
</resources>
